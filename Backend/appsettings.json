{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Backend.Services.TheftService": "Debug"
    }
  },
  "AllowedHosts": "*",
  // ── MQTT Broker ──────────────────────────────────────────────────────────
  "Mqtt": {
    "Server": "localhost",
    "Port": 1883
  },
  // ── TaurusDB (Huawei Cloud MySQL-compatible managed database) ─────────────
  // Replace every <PLACEHOLDER> with your real TaurusDB credentials.
  // Format: Server=<HOST>;Port=3306;Database=gridguard;Uid=<USER>;Pwd=<PASSWORD>;SslMode=Required;
  "ConnectionStrings": {
    "TaurusDB": "Server=<TAURUSDB_HOST>;Port=3306;Database=gridguard;Uid=<TAURUSDB_USER>;Pwd=<TAURUSDB_PASSWORD>;SslMode=Required;CharSet=utf8mb4;"
  },
  // ── Huawei Cloud Services ─────────────────────────────────────────────────
  "HuaweiCloud": {
    // ── OBS (Object Storage Service) — the "Evidence Locker" ─────────────
    // Stores raw electrical waveform JSON files.
    // AK/SK are created under: Huawei Cloud Console → My Credentials → Access Keys
    "OBS": {
      "AccessKey": "<HUAWEI_OBS_ACCESS_KEY>",
      "SecretKey": "<HUAWEI_OBS_SECRET_KEY>",
      "Endpoint": "https://obs.ap-southeast-3.myhuaweicloud.com",
      "BucketName": "gridguard-evidence",
      "Region": "ap-southeast-3"
    },
    // ── ModelArts Real-Time Inference Endpoint ────────────────────────────
    // Endpoint URL: ModelArts Console → Service Deployment → Real-Time Services → View
    // ApiToken:     IAM Console → My Credentials → Tokens (or use AK/SK signing instead)
    "ModelArts": {
      "InferenceEndpoint": "https://<MODEL_ARTS_ENDPOINT_ID>.modelarts.ap-southeast-3.myhuaweicloud.com/v1/infers/<SERVICE_ID>",
      "ApiToken": "<HUAWEI_IAM_TOKEN>"
    }
  }
}